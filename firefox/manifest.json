{
  "manifest_version": 3,
  "name": "Rockit",
  "version": "1.0.0",
  "description": "Switch between dev and prod for andrewbaldock.com and Aether.",
  "browser_specific_settings": {
    "gecko": {
      "id": "rockit@andrewbaldock.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "96":  "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "96":  "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:5173/*",
    "http://localhost:5174/*",
    "https://andrewbaldock.com/*",
    "https://aether.andrewbaldock.com/*"
  ]
}
